#!/usr/bin/env bash
# shellcheck shell=bash
set -euo pipefail

####################################################################
#  init-aiexclude — scaffold AI ignore files for a project
#
#  Usage:
#    init-aiexclude              # create files in current directory
#    init-aiexclude /path/to/dir # create files in given directory
#    init-aiexclude --sync       # regenerate targets from .aiexclude
#    init-aiexclude --check      # verify targets are in sync
####################################################################

# ANSI colors (respects NO_COLOR)
if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
else
    RED='\033[0;31m' GREEN='\033[0;32m' YELLOW='\033[1;33m' BLUE='\033[0;34m' NC='\033[0m'
fi

print_error()   { echo -e "${RED}Error: $*${NC}" >&2; }
print_success() { echo -e "${GREEN}$*${NC}"; }
print_info()    { echo -e "${BLUE}$*${NC}"; }
print_warning() { echo -e "${YELLOW}$*${NC}"; }

####################################################################
#  Configuration
####################################################################

SOURCE_NAME=".aiexclude"
TARGET_NAMES=(
    ".geminiignore"
    ".cursorignore"
    ".codeiumignore"
    ".aiignore"
    ".agentignore"
    ".crushignore"
)

####################################################################
#  Template — generic .aiexclude for any project
####################################################################

generate_template()
{
    cat << 'TEMPLATE'
# .aiexclude
#
# AI context exclusion patterns — keeps large, noisy, or sensitive
# files out of AI assistant context windows.
#
# This is the SINGLE SOURCE OF TRUTH for all AI ignore files.
# Run `init-aiexclude --sync` to regenerate tool-specific copies:
#   .geminiignore, .cursorignore, .codeiumignore, .aiignore, .agentignore

# IDE / editor

.idea/
*.iml
.vscode/
*.code-workspace
out/
.ruff_cache/
*~
*.swp
*.swo
*.tmp
.*.sw[a-z]

# Build artifacts

node_modules/
dist/
build/
bin/
.next/
out/
vendor/
.pnpm-store/
.yarn/cache/
.turbo/
*.tsbuildinfo

# Python

__pycache__/
*.py[cod]
*.so
.Python
.venv/
venv/
ENV/
env/
.eggs/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/

# Go

*.exe
*.exe~
*.dll
*.dylib
*.test
*.out
go.work
go.work.sum

# Test coverage

coverage/
.nyc_output/
test-results/
junit.xml

# Logs and runtime

*.log
logs/
*.pid
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Databases and local storage

*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
storage/

# Docker data

docker-data/
postgres-data/

# macOS

.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.TemporaryItems
.Trashes

# Windows

Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Archives

*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z
*.bz2
*.xz
*.gz

# Large media

*.mp4
*.mov
*.avi
*.mkv
*.iso
*.dmg
*.img

# SSL/TLS

*.pem
*.key
*.crt
*.cer

# Lock files

package-lock.json
yarn.lock
pnpm-lock.yaml
bun.lockb

# Allow example/template files
!.env.example
!.env.*.example
!*.template.*
TEMPLATE
}

####################################################################
#  Generate auto-generated header for target files
####################################################################

generate_header()
{
    local target_name="$1"
    cat << EOF
# AUTO-GENERATED — DO NOT EDIT
#
# Generated from .aiexclude by init-aiexclude
# Edit .aiexclude then run: init-aiexclude --sync
#
# Source: .aiexclude
# Target: ${target_name}
EOF
    echo ""
}

####################################################################
#  Extract content (skip ASCII art header if present, up to 50 lines)
####################################################################

extract_content()
{
    local source="$1"
    local first_pattern
    first_pattern="$(grep -n '^[^#[:space:]]' "${source}" | head -1 | cut -d: -f1)"

    if [[ -z "${first_pattern}" ]]; then
        cat "${source}"
    else
        local first_comment_before
        first_comment_before="$(head -n "$((first_pattern - 1))" "${source}" | grep -cn '^#' || true)"
        if [[ "${first_comment_before}" -gt 40 ]]; then
            tail -n +"$((first_comment_before + 1))" "${source}"
        else
            cat "${source}"
        fi
    fi
}

####################################################################
#  Sync targets from .aiexclude
####################################################################

sync_file()
{
    local dir="$1" target_name="$2"
    local target="${dir}/${target_name}"

    {
        generate_header "${target_name}"
        extract_content "${dir}/${SOURCE_NAME}"
    } > "${target}"

    print_success "  [OK] ${target_name}"
}

sync_all()
{
    local dir="$1"

    if [[ ! -f "${dir}/${SOURCE_NAME}" ]]; then
        print_error "${SOURCE_NAME} not found in ${dir}"
        exit 1
    fi

    print_info "Syncing AI ignore files from ${SOURCE_NAME}..."
    for name in "${TARGET_NAMES[@]}"; do
        sync_file "${dir}" "${name}"
    done
    echo ""
    print_success "Done — all AI ignore files updated."
}

####################################################################
#  Check if targets are in sync
####################################################################

check_sync()
{
    local dir="$1"
    local all_ok=true

    if [[ ! -f "${dir}/${SOURCE_NAME}" ]]; then
        print_error "${SOURCE_NAME} not found in ${dir}"
        exit 1
    fi

    print_info "Checking AI ignore files..."
    for name in "${TARGET_NAMES[@]}"; do
        local target="${dir}/${name}"
        local temp
        temp="$(mktemp)"

        {
            generate_header "${name}"
            extract_content "${dir}/${SOURCE_NAME}"
        } > "${temp}"

        if [[ ! -f "${target}" ]]; then
            print_warning "  [!] ${name} — missing"
            all_ok=false
        elif diff -q "${temp}" "${target}" > /dev/null 2>&1; then
            print_success "  [OK] ${name}"
        else
            print_warning "  [!] ${name} — out of sync"
            all_ok=false
        fi
        rm -f "${temp}"
    done

    echo ""
    if [[ "${all_ok}" == true ]]; then
        print_success "All files in sync."
    else
        print_error "Some files need updating. Run: init-aiexclude --sync"
        return 1
    fi
}

####################################################################
#  Init — create .aiexclude + all targets in a directory
####################################################################

init_project()
{
    local dir="$1"

    if [[ -f "${dir}/${SOURCE_NAME}" ]]; then
        print_warning "${SOURCE_NAME} already exists in ${dir}"
        read -rp "Overwrite? [y/N] " answer
        if [[ "${answer}" != [yY] ]]; then
            print_info "Skipped. Use --sync to regenerate targets from existing ${SOURCE_NAME}."
            exit 0
        fi
    fi

    print_info "Creating ${SOURCE_NAME} in ${dir}..."
    generate_template > "${dir}/${SOURCE_NAME}"
    print_success "  [OK] ${SOURCE_NAME}"

    for name in "${TARGET_NAMES[@]}"; do
        sync_file "${dir}" "${name}"
    done

    echo ""
    print_success "Done — 6 AI ignore files created."
    echo ""
    print_info "Next steps:"
    echo "  1. Edit ${SOURCE_NAME} to add project-specific patterns"
    echo "  2. Run: init-aiexclude --sync"
    echo "  3. Commit all files together"
}

####################################################################
#  Usage
####################################################################

show_usage()
{
    cat << EOF
Usage: init-aiexclude [OPTIONS] [DIRECTORY]

Scaffold AI context-exclusion files for a project.

Creates .aiexclude (source of truth) and generates:
  .geminiignore, .cursorignore, .codeiumignore, .aiignore, .agentignore

OPTIONS:
    --sync      Regenerate targets from existing .aiexclude
    --check     Verify targets are in sync with .aiexclude
    --help      Show this help

EXAMPLES:
    init-aiexclude              Create files in current directory
    init-aiexclude ~/project    Create files in ~/project
    init-aiexclude --sync       Regenerate from .aiexclude
    init-aiexclude --check      Check sync status
EOF
}

####################################################################
#  Main
####################################################################

main()
{
    local mode="init"
    local dir="."

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --sync)  mode="sync";  shift ;;
            --check) mode="check"; shift ;;
            --help | -h) show_usage; exit 0 ;;
            -*) print_error "Unknown option: $1"; show_usage; exit 1 ;;
            *)  dir="$1"; shift ;;
        esac
    done

    dir="$(cd "${dir}" && pwd)"

    case "${mode}" in
        init)  init_project "${dir}" ;;
        sync)  sync_all "${dir}" ;;
        check) check_sync "${dir}" ;;
    esac
}

main "$@"
