# -------------------------------------
#
# ~/.zprofile in a nice manner
#
# -------------------------------------

# Est. 2026-03-28 Happy BirthDay!

####################################################################

# How zsh picks a login profile:
#
# 1. ~/.zshenv    (always, every shell)
# 2. ~/.zprofile  (login shells only — this file)
# 3. ~/.zshrc     (interactive shells)
# 4. ~/.zlogin    (login shells, after .zshrc)

# .zprofile is the zsh equivalent of bash's .bash_profile.
# Use it for commands that should run only once per login session,
# such as setting environment variables and PATH.

####################################################################

export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8
export LANG=en_US.UTF-8

####################################################################
####################################################################
####################################################################
### HOMEBREW #######################################################
####################################################################
####################################################################
####################################################################

if [[ -x /opt/homebrew/bin/brew ]]; then
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

export HOMEBREW_INSTALL_FROM_API=1
export HOMEBREW_NO_ANALYTICS=1

export NONINTERACTIVE=0

####################################################################
####################################################################
####################################################################
### NVM ############################################################
####################################################################
####################################################################
####################################################################

export NVM_DIR="${HOME}/.nvm"
if [[ -d "${NVM_DIR}" ]]; then
    [[ -s "${NVM_DIR}/nvm.sh" ]] && . "${NVM_DIR}/nvm.sh"
    [[ -s "${NVM_DIR}/bash_completion" ]] && . "${NVM_DIR}/bash_completion"
fi

####################################################################
####################################################################
####################################################################
### GIT ############################################################
####################################################################
####################################################################
####################################################################

export GIT_PS1_SHOWCOLORHINTS=1
export GIT_PS1_SHOWDIRTYSTATE=1
export GIT_PS1_STATESEPARATOR=" · "

####################################################################
####################################################################
####################################################################
### GREP ###########################################################
####################################################################
####################################################################
####################################################################

export GREP_COLOR='1;32'

####################################################################
####################################################################
####################################################################
### CLI & GUI EDITORS ##############################################
####################################################################
####################################################################
####################################################################

if command -v micro &>/dev/null; then
    export EDITOR=micro
else
    export EDITOR=nano
fi

if command -v zed &>/dev/null; then
    export VISUAL=zed
else
    export VISUAL=subl
fi

####################################################################
####################################################################
####################################################################
### pyenv (Python) #################################################
####################################################################
####################################################################
####################################################################

export PYTHONWARNINGS="ignore::DeprecationWarning"
export PYENV_VIRTUALENV_DISABLE_PROMPT=0
export PYENV_ROOT="${HOME}/.pyenv"
if [[ -d "${PYENV_ROOT}/bin" ]]; then
    export PATH="${PYENV_ROOT}/bin:${PATH}"
fi

####################################################################
####################################################################
####################################################################
### PSQL & PGPASS ##################################################
####################################################################
####################################################################
####################################################################

if [[ -d "${HOMEBREW_PREFIX}/opt/libpq/bin" ]]; then
    export PATH="${HOMEBREW_PREFIX}/opt/libpq/bin:${PATH}"
fi
export PGPASSFILE="${HOME}/.pgpass"

####################################################################
####################################################################
####################################################################
### gcloud (Google Cloud) ##########################################
####################################################################
####################################################################
####################################################################

if [[ -d "${HOME}/.local/share/google-cloud-sdk/bin" ]]; then
    export PATH="${HOME}/.local/share/google-cloud-sdk/bin:${PATH}"
fi

if [[ -s "${HOME}/.local/share/google-cloud-sdk/path.zsh.inc" ]]; then
    . "${HOME}/.local/share/google-cloud-sdk/path.zsh.inc"
fi

####################################################################
####################################################################
####################################################################
### Atlassian (non-secret config) ##################################
####################################################################
####################################################################
####################################################################

export CONFLUENCE_DOMAIN=""
export CONFLUENCE_EMAIL=""

####################################################################
####################################################################
####################################################################
### SECRETS (tokens, passwords, credentials) #######################
####################################################################
####################################################################
####################################################################

if [[ -r "${HOME}/.secrets" ]]; then
    source "${HOME}/.secrets"
fi

####################################################################
####################################################################
####################################################################
### PATH additions #################################################
####################################################################
####################################################################
####################################################################

[[ -d "/opt/homebrew/opt/mysql-client/bin" ]] && export PATH="/opt/homebrew/opt/mysql-client/bin:${PATH}"
[[ -d "/opt/local/bin" ]] && export PATH="/opt/local/bin:/opt/local/sbin:${PATH}"
[[ -d "${HOME}/.lmstudio/bin" ]] && export PATH="${PATH}:${HOME}/.lmstudio/bin"
[[ -d "${HOME}/go/bin" ]] && export PATH="${PATH}:${HOME}/go/bin"

export BUN_INSTALL="${HOME}/.bun"
[[ -d "${BUN_INSTALL}/bin" ]] && export PATH="${BUN_INSTALL}/bin:${PATH}"

####################################################################

[[ -s "${HOME}/.local/bin/env" ]] && . "${HOME}/.local/bin/env"
