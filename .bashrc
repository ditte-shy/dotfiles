# -------------------------------------
#
# ~/.bashrc in a nice manner
#
# -------------------------------------

# Est. 2024-06-13 Happy BirthDay!

####################################################################

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

####################################################################

shopt -s checkwinsize

####################################################################
####################################################################
####################################################################
### BASH COMPLETION ################################################
####################################################################
####################################################################
####################################################################

if [[ -n "${HOMEBREW_PREFIX}" ]]; then
    # shellcheck disable=SC1091
    if [[ -r "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh" ]]; then
        source "${HOMEBREW_PREFIX}/etc/profile.d/bash_completion.sh"
    else
        for COMPLETION in "${HOMEBREW_PREFIX}/etc/bash_completion.d/"*; do
            # shellcheck disable=SC1090
            [[ -r "${COMPLETION}" ]] && source "${COMPLETION}"
        done
    fi
fi

####################################################################
####################################################################
####################################################################
### BASH PROMPT ####################################################
####################################################################
####################################################################
####################################################################

export PS1="
    \[${PURPLE}\]\u · \h\[${NC}\] · \[${LIGHT_GRAY}\]\D{%A %Y-%m-%d · %H:%M:%S}\[${NC}\]
    \[${PURPLE}\]\w\[${NC}\] \[${NC}\]\$(__git_ps1 \"· %s\")\[${NC}\]
    \n\[${PURPLE}\]⏻\[${NC}\] "

####################################################################

export PS2='> '
export PS3='#? '
export PS4='+ '

####################################################################
####################################################################
####################################################################
### BASH HISTORY ###################################################
####################################################################
####################################################################
####################################################################

bind '"\e[A": history-search-backward'
bind '"\e[B": history-search-forward'
bind '"\e[1;5C":forward-word'
bind '"\e[1;5D":backward-word'
shopt -s histappend
PROMPT_COMMAND='history -a'

export HISTSIZE=1000000
export HISTTIMEFORMAT='%F %T '
export HISTCONTROL=ignoredups

####################################################################
####################################################################
####################################################################
### FZF (Fuzzy find) ###############################################
####################################################################
####################################################################
####################################################################

if [[ -f /opt/homebrew/bin/fzf ]]; then

    eval "$(fzf --bash)"

    export FZF_DEFAULT_COMMAND="fd --hidden"
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND="$FZF_DEFAULT_COMMAND --type d"

fi

####################################################################
####################################################################
####################################################################
### HCLOUD (Hetzner Cloud) #########################################
####################################################################
####################################################################
####################################################################

if command -v hcloud &>/dev/null; then
    # shellcheck disable=SC1090
    source <(hcloud completion bash)
fi

####################################################################
####################################################################
####################################################################
### PGPASSFILE #####################################################
####################################################################
####################################################################
####################################################################

if [[ -f "${PGPASSFILE}" ]]; then
    chown "${USER}:staff" "${PGPASSFILE}" 2>/dev/null
    chmod 0600 "${PGPASSFILE}" 2>/dev/null
fi

####################################################################
####################################################################
####################################################################
### ALIASES ########################################################
####################################################################
####################################################################
####################################################################

if [[ -s "${HOME}/.bash_aliases" ]]; then
    # shellcheck disable=SC1090
    source "${HOME}/.bash_aliases"
fi

####################################################################
####################################################################
####################################################################
### FUNCTIONS ######################################################
####################################################################
####################################################################
####################################################################

if [[ -s "${HOME}/.bash_functions" ]]; then
    # shellcheck disable=SC1090
    source "${HOME}/.bash_functions"
fi

####################################################################
####################################################################
####################################################################
### TOOL INTEGRATIONS ##############################################
####################################################################
####################################################################
####################################################################

if command -v thefuck &>/dev/null; then
    eval "$(thefuck --alias)"
fi
