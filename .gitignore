# Ignore everything by default
*

# Whitelist dotfiles
!.gitignore
!.bash_profile
!.bashrc
!.bash_aliases
!.bash_functions

# Config directory
!.config/
!.config/terminal/
!.config/terminal/*
!.config/mc/
!.config/mc/**
.config/mc/hotlist
!.config/lazydocker/
!.config/lazydocker/config.yml

# Never track secrets
.secrets

# OS junk
.DS_Store
