// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
    "icon_theme": {
        "mode": "system",
        "light": "Zed (Default)",
        "dark": "Zed (Default)",
    },
    "diagnostics": {
        "button": true,
    },
    "disable_ai": false,
    "linked_edits": true,
    "completions": {
        "lsp": true,
    },
    "colorize_brackets": true,
    "inlay_hints": {
        "enabled": false,
    },
    "which_key": {
        "enabled": false,
    },
    "use_smartcase_search": true,
    "active_pane_modifiers": {
        "inactive_opacity": 1.0,
    },
    "use_system_window_tabs": false,
    "bottom_dock_layout": "contained",
    "preview_tabs": {
        "enable_preview_from_file_finder": true,
        "enable_preview_from_multibuffer": false,
        "enable_preview_from_project_panel": true,
        "enabled": false,
    },
    "title_bar": {
        "show_project_items": true,
        "show_onboarding_banner": false,
        "show_user_picture": false,
        "show_user_menu": false,
        "show_sign_in": false,
    },
    "debugger": {
        "button": false,
    },
    "status_bar": {
        "cursor_position_button": true,
    },
    "search": {
        "center_on_match": true,
        "button": false,
    },
    "lsp": {
        "vtsls": {
            "settings": {
                "typescript": {
                    "updateImportsOnFileMove": {
                        "enabled": "false",
                    },
                },
                "javascript": {
                    "updateImportsOnFileMove": {
                        "enabled": "false",
                    },
                },
            },
            "enable_lsp_tasks": true,
        },
    },
    "enable_language_server": true,
    "audio": {
        "experimental.legacy_audio_compatible": false,
    },
    "agent_servers": {
        "mlx-ml": {
            "type": "custom",
            "command": "path_to_executable",
            "args": [],
            "env": {},
            "favorite_models": [],
            "default_config_options": {},
            "favorite_config_option_values": {},
        },
    },
    "git_panel": {
        "status_style": "icon",
        "button": false,
        "tree_view": true,
    },
    "prettier": {
        "allowed": true,
        "formatter": {
            // Enable Prettier formatting
            "format_on_save": "on",
            // Use project-specific Prettier config
            "use_project_config": true,
        },
    },
    "languages": {
        "TypeScript": {
            "formatter": "prettier",
            "format_on_save": "on",
        },
        "TSX": {
            "formatter": "prettier",
            "format_on_save": "on",
        },
        "JavaScript": {
            "formatter": "prettier",
            "format_on_save": "on",
        },
        "JSON": {
            "formatter": "prettier",
            "format_on_save": "on",
        },
        "Markdown": {
            "formatter": "prettier",
            "format_on_save": "on",
            "language_servers": ["marksman"],
        },
        "CSS": {
            "formatter": "prettier",
            "format_on_save": "on",
        },
        "Go": {
            "formatter": "language_server",
            "format_on_save": "on",
            "prettier": {
                "allowed": false,
            },
        },
        "Shell Script": {
            "colorize_brackets": true,
            "formatter": "language_server",
            "format_on_save": "on",
            "prettier": {
                "allowed": false,
            },
        },
        "SQL": {
            "formatter": "language_server",
            "format_on_save": "on",
            "prettier": {
                "allowed": false,
            },
        },
        "Make": {
            "formatter": "language_server",
            "format_on_save": "on",
            "prettier": {
                "allowed": false,
            },
        },
        "CSV": {
            "formatter": "language_server",
            "format_on_save": "on",
            "prettier": {
                "allowed": false,
            },
        },
    },
    "context_servers": {
        "mcp-server-sequential-thinking": {
            "enabled": false,
            "remote": false,
            "settings": {},
        },
        "bun-docs-mcp": {
            "enabled": false,
            "remote": false,
            "settings": {},
        },
        "mcp-server-nextjs": {
            "enabled": false,
            "remote": false,
            "settings": {},
        },
        "mcp-server-context7": {
            "enabled": false,
            "settings": {
                "context7_api_key": "",
            },
        },
        "terraform-context-server": {
            "enabled": false,
            "settings": {},
        },
        "mcp-server-github": {
            "enabled": false,
            "settings": {
                "github_personal_access_token": "",
            },
        },
        "postgres-context-server": {
            "enabled": false,
            "settings": {
                "database_url": "postgresql://engineer__develop:The%20Development%20Secret%20Is%20Not%20For%20Production%21@localhost:6000/develop",
            },
        },
    },
    "redact_private_values": false,
    "show_wrap_guides": true,
    "edit_predictions": {
        "provider": "copilot",
        "disabled_globs": [
            "node_modules/",
            "dist/",
            "build/",
            ".next/",
            "tmp/",
            "logs/",
        ],
        "mode": "eager",
    },
    "outline_panel": {
        "button": true,
        "dock": "left",
    },
    "theme": {
        "mode": "system",
        "light": "One Light",
        "dark": "One Dark",
    },
    "ui_font_size": 16.0,
    "buffer_font_size": 16.0,
    // The name of a font to use for rendering text in the UI
    // "ui_font_family": ".SystemUIFont",
    "ui_font_family": "Ubuntu",
    // "ui_font_family": "Syne Mono",
    // "buffer_font_family": "Monofur NFM",
    // "buffer_font_family": "monofur",
    "buffer_font_family": "Syne Mono",
    "base_keymap": "SublimeText",
    "buffer_line_height": {
        "custom": 1.1,
    },
    "telemetry": {
        // Send debug info like crash reports.
        "diagnostics": false,
        // Send anonymized usage data like what languages you're using Zed with.
        "metrics": false,
    },
    "project_panel": {
        // Whether to show the project panel button in the status bar
        "bold_folder_labels": false,
        "entry_spacing": "standard",
        "hide_hidden": false,
        "hide_root": true,
        "button": false,
        "file_icons": false,
        // Whether to show folder icons or chevrons for directories in the project panel.
        "folder_icons": false,
        // Whether to show the git status in the project panel.
        "git_status": true,
        // Amount of indentation for nested items.
        "indent_size": 8,
    },
    "collaboration_panel": {
        // Whether to show the collaboration panel button in the status bar.
        "button": false,
    },
    "message_editor": {
        // Whether to automatically replace emoji shortcodes with emoji characters.
        // For example: typing `:wave:` gets replaced with `👋`.
        "auto_replace_emoji_shortcode": false,
    },
    "notification_panel": {
        // Whether to show the notification panel button in the status bar.
        "button": false,
    },
    "agent": {
        // Version of this setting.
        // Whether the assistant is enabled.
        "tool_permissions": {
            "default": "allow",
        },
        "show_turn_stats": true,
        "inline_assistant_model": {
            "provider": "ollama",
            "model": "magistral:24b",
        },
        "favorite_models": [
            {
                "provider": "copilot_chat",
                "model": "claude-sonnet-4.6",
            },
            {
                "provider": "copilot_chat",
                "model": "claude-opus-4.6",
            },
        ],
        "default_profile": "write",
        "dock": "left",
        "default_model": {
            "provider": "copilot_chat",
            "model": "claude-sonnet-4.6",
        },
        "enable_feedback": false,
        "enabled": true,
        // Whether to show the assistant panel button in the status bar.
        "button": false,
    },
    // Whether the screen sharing icon is shown in the os status bar.
    "show_call_status_icon": false,
    "autosave": "on_focus_change",
    // Settings related to the editor's tab bar.
    "tab_bar": {
        // Whether or not to show the tab bar in the editor
        "show_tab_bar_buttons": false,
        "show": false,
        // Whether or not to show the navigation history buttons.
        "show_nav_history_buttons": false,
    },
    "auto_update": true,
    // Settings related to the editor's tabs
    "tabs": {
        // Show git status colors in the editor tabs.
        "show_close_button": "hidden",
        "git_status": false,
        // Position of the close button on the editor tabs.
        "close_position": "left",
    },
    "toolbar": {
        // Whether to show breadcrumbs.
        "code_actions": false,
        "breadcrumbs": true,
        // Whether to show quick action buttons.
        "quick_actions": false,
        // Whether to show the Selections menu in the editor toolbar
        "selections_menu": true,
    },
    "wrap_guides": [80],
    // 1. Do not soft wrap.
    //      "soft_wrap": "none",
    // 2. Prefer a single line generally, unless an overly long line is encountered.
    //      "soft_wrap": "prefer_line",
    // 3. Soft wrap lines that overflow the editor:
    //      "soft_wrap": "editor_width",
    // 4. Soft wrap lines at the preferred line length
    //      "soft_wrap": "preferred_line_length",
    "soft_wrap": "none",
    "terminal": {
        "default_width": 640.0,
        "working_directory": "current_project_directory",
        "dock": "left",
        "toolbar": {
            "breadcrumbs": false,
        },
        "blinking": "on",
        "cursor_shape": "bar",
        "shell": "system",
        // Whether to show the terminal button in the status bar
        "button": false,
        "line_height": {
            "custom": 1.1,
        },
        "font_size": 16,
    },
    "file_scan_exclusions": [
        "node_modules",
        "next",
        ".pnpm-store",
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/.classpath",
        "**/.settings",
        "*.pdf",
        "*.zip",
        "*.dump",
        "*.sqlite",
        "*.docx",
        "*.xlsx",
        "**/Icon",
    ],
}
